# Include https:// (domain-only values like proyavevent.com.ua also work)
NEXT_PUBLIC_SITE_URL=https://proyav.ua

WAYFORPAY_MERCHANT_ACCOUNT=your_merchant_login
WAYFORPAY_SECRET_KEY=your_secret_key
WAYFORPAY_MERCHANT_PASSWORD=your_merchant_password

RESEND_API_KEY=re_xxx
EMAIL_FROM=info@your-verified-domain.com

# JSON: {"PROMO_CODE": discount_percent}
PROMO_CODES={"SPEAKER10":10,"BLOGER15":15}

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
ADMIN_SESSION_SECRET=generate-a-long-random-string

# SQLite database path (default: data/proyav.db)
SQLITE_PATH=
